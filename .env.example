# ─────────────────────────────────────────────
#  NeuroFlow Backend — Variables de Entorno
# ─────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=development

# MongoDB — reemplaza <user>, <password> y <dbname>
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# CORS — origen(s) permitidos (separados por coma si son varios)
# En desarrollo usa http://localhost:5173 o http://127.0.0.1:5500
# En producción usa tu dominio real: https://neuroflow.app
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
